# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/devops_tracker?schema=public"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production

# Encryption (any length string; PBKDF2 derives the 32-byte AES-256 key internally)
ENCRYPTION_KEY=change_this_to_a_strong_secret_phrase

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
