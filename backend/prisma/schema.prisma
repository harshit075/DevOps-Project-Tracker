// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DEVOPS_ENGINEER
  VIEWER
}

enum ServiceStatus {
  HEALTHY
  WARNING
  DOWN
}

enum PipelineStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum DeploymentStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  ROLLED_BACK
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TodoStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  role          Role     @default(VIEWER)
  created_at    DateTime @default(now())

  @@map("users")
}

model Environment {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  created_at  DateTime  @default(now())
  services    Service[]

  @@map("environments")
}

model Service {
  id               String        @id @default(uuid())
  name             String
  status           ServiceStatus @default(HEALTHY)
  version          String?
  last_deployment  DateTime?
  environment_id   String?
  environment      Environment?  @relation(fields: [environment_id], references: [id], onDelete: SetNull)
  created_at       DateTime      @default(now())
  deployments      Deployment[]

  @@map("services")
}

model Pipeline {
  id           String         @id @default(uuid())
  name         String
  status       PipelineStatus @default(PENDING)
  commit_hash  String?
  duration     Int?
  triggered_by String?
  created_at   DateTime       @default(now())

  @@map("pipelines")
}

model Deployment {
  id          String           @id @default(uuid())
  service_id  String?
  service     Service?         @relation(fields: [service_id], references: [id], onDelete: SetNull)
  environment String
  commit_hash String?
  status      DeploymentStatus @default(PENDING)
  version     String?
  created_at  DateTime         @default(now())

  @@map("deployments")
}

model Credential {
  id              String   @id @default(uuid())
  name            String
  type            String
  encrypted_value String
  created_at      DateTime @default(now())

  @@map("credentials")
}

model Todo {
  id          String     @id @default(uuid())
  title       String
  description String?
  priority    Priority   @default(MEDIUM)
  status      TodoStatus @default(PENDING)
  created_at  DateTime   @default(now())

  @@map("todos")
}

model Documentation {
  id         String   @id @default(uuid())
  title      String
  content    String
  category   String
  created_at DateTime @default(now())

  @@map("documentation")
}
